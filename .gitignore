# ─────────────────────────────────────────────────────────────────────────────
# ThingsPanel All-in-One — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# 环境变量（含密码，绝对不入库）
.env
*.env.local

# 数据目录
data/
images/

# 构建产物
dist/

# macOS
.DS_Store
__MACOSX/

# Windows
Thumbs.db
Desktop.ini

# 临时文件
packaging/macos/.build/
*.bak
*.bak.*

# IDE
.vscode/settings.json
.idea/
*.swp

# 临时补丁脚本（本地开发工具，不提交）
patch_*.py
rewrite_*.py
