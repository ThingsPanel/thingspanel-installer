<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
  <title>ThingsPanel</title>
  <welcome file="welcome.html" mime-type="text/html"/>
  <readme file="readme.html" mime-type="text/html"/>
  <license file="license.html" mime-type="text/html"/>
  <conclusion file="conclusion.html" mime-type="text/html"/>

  <options customize="never" require-scripts="true" hostArchitectures="x86_64,arm64"/>
  <domains enable_anywhere="false" enable_currentUserHome="false" enable_localSystem="true"/>

  <choices-outline>
    <line choice="default"/>
  </choices-outline>

  <choice id="default" title="ThingsPanel Installer">
    <pkg-ref id="io.thingspanel.installer"/>
  </choice>

  <pkg-ref id="io.thingspanel.installer" version="0" onConclusion="none">thingspanel-component.pkg</pkg-ref>
</installer-gui-script>
