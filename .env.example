# ─────────────────────────────────────────────────────────────────────────────
# ThingsPanel All-in-One — 环境变量配置
# 复制此文件为 .env 并按需修改
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── 版本控制（通常由 install.sh 自动填写，无需手动修改）─────────────────────
TP_VERSION=v1.1.13.6
TP_VUE_VERSION=v1.1.13.6
TP_BACKEND_VERSION=v1.1.13.6
TP_GMQTT_VERSION=v1.1.6
TP_REDIS_VERSION=6.2.7
TP_MODBUS_VERSION=v1.0.6.1
TP_HTTP_ADAPTER_VERSION=v1.0.0
TP_THINGSVIS_SERVER_VERSION=v1.0.4
TP_THINGSVIS_STUDIO_VERSION=v1.0.4
TP_TIMESCALEDB_VERSION=14

# ── 安全凭证（务必修改！install.sh 会自动生成随机值）──────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
REDIS_PASSWORD=CHANGE_ME_redis_password
AUTH_SECRET=CHANGE_ME_auth_secret_at_least_32_chars

# ── 数据目录（存放数据库、文件等持久化数据）────────────────────────────────────
# Linux/macOS 推荐: /opt/thingspanel/data
# Windows 推荐:    C:\ThingsPanel\data（install.ps1 自动设置）
DATA_DIR=./data

# ── 端口配置（如有冲突可修改）────────────────────────────────────────────────
HTTP_PORT=8080        # Web 界面访问端口
MQTT_PORT=1883        # MQTT 设备接入端口
MODBUS_TCP_PORT=502   # Modbus TCP 端口
MODBUS_RTU_PORT=503   # Modbus RTU 端口

# ── 时区 ─────────────────────────────────────────────────────────────────────
TZ=Asia/Shanghai

# ── 日志级别（debug/info/warn/error）────────────────────────────────────────
TP_LOG_LEVEL=error
